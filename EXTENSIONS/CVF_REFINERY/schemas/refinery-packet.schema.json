{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cvf.local/schemas/refinery-packet.schema.json",
  "title": "CVF RefineryPacket",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "refinery_packet_id",
    "source_envelopes",
    "normalized_records",
    "duplicate_groups",
    "conflict_sets",
    "quality_findings",
    "integrity_results",
    "transformation_lineage",
    "declared_scope",
    "declared_owner",
    "rule_manifest",
    "status",
    "failure_tokens",
    "created_at_utc"
  ],
  "properties": {
    "refinery_packet_id": { "type": "string", "minLength": 1 },
    "source_envelopes": { "type": "array", "items": { "$ref": "source-envelope.schema.json" } },
    "normalized_records": { "type": "array", "items": { "type": "object" } },
    "duplicate_groups": { "type": "array", "items": { "type": "object" } },
    "conflict_sets": { "type": "array", "items": { "type": "object" } },
    "quality_findings": { "type": "array", "items": { "type": "object" } },
    "integrity_results": { "type": "array", "items": { "type": "object" } },
    "transformation_lineage": { "type": "array", "items": { "type": "object" }, "minItems": 1 },
    "declared_scope": { "type": "object", "required": ["organization"] },
    "declared_owner": { "type": "string" },
    "rule_manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manifest_id", "version"],
      "properties": {
        "manifest_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "status": { "enum": ["IN_PROGRESS", "READY_FOR_KERNEL", "REVIEW_REQUIRED", "BLOCKED"] },
    "failure_tokens": {
      "type": "array",
      "items": { "enum": ["REFINERY_NO_STAGES_EXECUTED", "QUALITY_CHECK_FAILED", "INTEGRITY_CHECK_FAILED", "SCHEMA_VALIDATION_FAILED"] }
    },
    "created_at_utc": { "type": "string", "pattern": "Z$" }
  },
  "allOf": [
    {
      "if": { "properties": { "status": { "enum": ["REVIEW_REQUIRED", "BLOCKED"] } }, "required": ["status"] },
      "then": { "properties": { "failure_tokens": { "minItems": 1 } } }
    },
    {
      "if": { "properties": { "status": { "enum": ["IN_PROGRESS", "READY_FOR_KERNEL"] } }, "required": ["status"] },
      "then": { "properties": { "failure_tokens": { "maxItems": 0 } } }
    }
  ]
}
