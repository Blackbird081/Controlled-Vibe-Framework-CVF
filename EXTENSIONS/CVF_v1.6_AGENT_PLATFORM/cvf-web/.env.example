# CVF Web UI - Environment Configuration
# Copy this file to .env.local and fill in your API keys

# ===========================================
# AI Provider API Keys
# ===========================================
# At least ONE provider must be configured

# OpenAI (GPT-4, GPT-4o)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic (Claude 3.5)
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google (Gemini 2.0)
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Alibaba DashScope / Qwen
# Canonical env for all CVF live tests, execute routes, and runtime validation.
# Compatibility aliases still accepted in code: CVF_BENCHMARK_ALIBABA_KEY, CVF_ALIBABA_API_KEY
ALIBABA_API_KEY=

# DeepSeek
# OpenAI-compatible endpoint: https://api.deepseek.com/chat/completions
DEEPSEEK_API_KEY=

# ===========================================
# Default Provider
# ===========================================
# Options: openai, claude, gemini, alibaba, openrouter, deepseek
DEFAULT_AI_PROVIDER=openai

# ===========================================
# CVF v1.6.1 Governance Engine
# ===========================================
# URL of the FastAPI governance server (default: http://localhost:8000)
GOVERNANCE_ENGINE_URL=http://localhost:8000

# Enable/disable governance engine integration (default: true)
# When disabled, falls back to client-side governance logic
GOVERNANCE_ENGINE_ENABLED=true

# Request timeout in ms (default: 5000)
GOVERNANCE_ENGINE_TIMEOUT=5000

# ===========================================
# Authentication
# ===========================================
# CVF_ADMIN_USER=admin
# CVF_ADMIN_PASS=admin123
# CVF_SERVICE_TOKEN=your-service-token-here
# CVF_INTERNAL_AUDIT_SECRET=required-for-admin-route-audit-posts

# ===========================================
# Optional Settings
# ===========================================
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Enable mock AI mode (UI demo only)
# NEXT_PUBLIC_CVF_MOCK_AI=1

# Optional: override model pricing JSON (for /api/pricing)
# MODEL_PRICING_JSON={"openai":{"gpt-4o":{"input":5,"output":15}}}
