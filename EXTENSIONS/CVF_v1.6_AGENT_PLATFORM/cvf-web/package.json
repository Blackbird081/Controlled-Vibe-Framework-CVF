{
  "name": "cvf-agent",
  "version": "1.7.0",
  "private": true,
  "scripts": {
    "sync:risk-models": "node scripts/build-risk-models.js",
    "predev": "node scripts/build-risk-models.js && node scripts/build-skill-index.js",
    "prebuild": "node -e \"const fs=require('fs');const d=process.env.NEXT_DIST_DIR||'.next';try{fs.rmSync(d,{recursive:true,force:true})}catch(e){}\" && node scripts/build-risk-models.js && node scripts/build-skill-index.js",
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run --exclude \"src/**/*.live.test.ts\"",
    "test:coverage": "vitest run --coverage --exclude \"src/**/*.live.test.ts\"",
    "test:live": "vitest run \"src/**/*.live.test.ts\" --fileParallelism=false",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "cvf-control-plane-foundation": "file:../../CVF_CONTROL_PLANE_FOUNDATION",
    "cvf-execution-plane-foundation": "file:../../CVF_EXECUTION_PLANE_FOUNDATION",
    "cvf-guard-contract": "file:../../CVF_GUARD_CONTRACT",
    "cvf-learning-plane-foundation": "file:../../CVF_LEARNING_PLANE_FOUNDATION",
    "cvf-refinery": "file:../../CVF_REFINERY",
    "cvf-truth-flow": "file:../../CVF_TRUTH_FLOW",
    "cvf-truth-kernel": "file:../../CVF_TRUTH_KERNEL",
    "docx": "^9.5.2",
    "file-saver": "^2.0.5",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.563.0",
    "next": "16.2.7",
    "next-auth": "^5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.0"
  }
}
