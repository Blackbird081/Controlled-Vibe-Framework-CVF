{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cvf.local/schemas/governed-packs/strategy_analysis/receipt.schema.json",
  "title": "CVF Strategy Analysis Receipt",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "templateId",
    "role",
    "policyVersion",
    "providerLane",
    "dlpResult",
    "quotaResult",
    "stepTraces",
    "issuedAt"
  ],
  "properties": {
    "templateId": {
      "const": "strategy_analysis"
    },
    "role": {
      "const": "BUILDER"
    },
    "policyVersion": {
      "type": "string"
    },
    "providerLane": {
      "type": "string"
    },
    "dlpResult": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "blocked",
            "needs_review"
          ]
        }
      }
    },
    "quotaResult": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "enum": [
            "pass",
            "blocked",
            "degraded"
          ]
        }
      }
    },
    "stepTraces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "step",
          "status"
        ],
        "properties": {
          "step": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "evidenceRef": {
            "type": "string"
          }
        }
      }
    },
    "issuedAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}

