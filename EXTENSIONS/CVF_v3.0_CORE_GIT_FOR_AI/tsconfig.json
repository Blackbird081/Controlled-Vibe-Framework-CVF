{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": [
            "node"
        ],
        "esModuleInterop": true,
        "strict": true,
        "outDir": "dist",
        "declaration": true,
        "skipLibCheck": true
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "dist",
        "node_modules",
        "coverage"
    ]
}
