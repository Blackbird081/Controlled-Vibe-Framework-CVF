      "description": "Candidate for curated public package/repo/release export after separate approval."
    },
    {
      "id": "INTERNAL_ONLY",
      "description": "Internal working surface; not intended for direct public release."
    },
    {
      "id": "PRIVATE_ENTERPRISE_ONLY",
      "description": "Enterprise-private or commercially sensitive surface that should remain non-public by default."
    }
  ],
