{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cvf.local/schemas/skill-pack/risk.profile.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "riskLevel",
    "riskRationale",
    "allowedDataClasses",
    "disallowedDataClasses",
    "humanReviewRequired"
  ],
  "properties": {
    "riskLevel": {
      "enum": [
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "riskRationale": {
      "type": "string",
      "minLength": 1
    },
    "allowedDataClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "disallowedDataClasses": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "humanReviewRequired": {
      "type": "boolean"
    }
  }
}
